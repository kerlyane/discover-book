<header>
     <link rel="stylesheet" href="/css/header.css">
    <div class="logo">
        <img src="/img/logo.png" alt="Logo DiscoverBook" class="logo-img">
    </div>

    <!-- BARRA DE PESQUISA -->
    <div class="search-container">
        <input
            type="text"
            id="searchInput"
            placeholder="Buscar livros..."
        >

        <button>
            <i class="fi fi-rr-search"></i>
        </button>

        <span class="limpar" onclick="limparBusca()">
            Limpar
        </span>

        <div id="resultadosBusca" class="resultados"></div>
    </div>

<% if(usuario){ %>

<div class="perfil-header">

    <a href="/perfil">

        <img
            src="<%= usuarioFoto || '/img/perfil-padrao.png' %>"
            class="foto-header"
        >

    </a>

    <div>

        <strong><%= usuario %></strong>

        <br>

        <a href="/logout">Sair</a>

    </div>

</div>

<% } else { %>

<div class="btn-login">

    <a href="/cadastro">
        Cadastre-se
    </a>

</div>

<% } %>

</header>


<header>
    <div class="logo">
        <img src="/img/logo.png" alt="Logo DiscoverBook" class="logo-img">
    </div>

    <% if (typeof usuario !== 'undefined' && usuario) { %>
        <div class="btn-login">
            <span>Olá, <%= usuario %></span>
            <a href="/logout">Sair</a>
        </div>
    <% } else { %>
        <div class="btn-login">
            <a href="/cadastro">Cadastre-se</a>
        </div>
    <% } %>
</header>